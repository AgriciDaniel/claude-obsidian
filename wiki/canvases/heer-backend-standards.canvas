      "height": 60
    },
    {
      "id": "next-audit",
      "type": "text",
      "text": "## Next: WebSocket Audit\n⬜ Socket.io gateway authorization\n⬜ Room join validation\n⬜ Event rate limiting",
      "x": -60,
